# ===== QuizJeto configuration (TEMPLATE) =====
# Copy this file to ".env" and fill in real values.
# NEVER commit the real ".env" to git — only this .example file.

# --- bdapps (Robi Axiata) app credentials ---
# Get these from your app's page at https://developer.bdapps.com
BDAPPS_APP_ID=
BDAPPS_PASSWORD=
BDAPPS_APP_NAME=QuizJeto

# --- bdapps API endpoints (defaults are correct; override only if bdapps tells you to) ---
BDAPPS_OTP_REQUEST_URL=https://developer.bdapps.com/subscription/otp/request
BDAPPS_OTP_VERIFY_URL=https://developer.bdapps.com/subscription/otp/verify
BDAPPS_SUBSCRIPTION_URL=https://developer.bdapps.com/subscription/send
BDAPPS_SUBSCRIPTION_STATUS_URL=https://developer.bdapps.com/subscription/getstatus
BDAPPS_SMS_URL=https://developer.bdapps.com/sms/send
# Charging + USSD URLs are app-specific — copy them from your bdapps dashboard:
BDAPPS_CHARGING_URL=
BDAPPS_USSD_URL=

# --- Database ---
# Use "sqlite" for now (no server needed). Switch to "mysql" for production.
DB_CONNECTION=sqlite
DB_SQLITE_PATH=database/quizjeto.sqlite
# MySQL settings (only used when DB_CONNECTION=mysql)
DB_HOST=127.0.0.1
DB_NAME=quizjeto
DB_USER=root
DB_PASS=

# --- App behaviour ---
# Set to "true" in production to enforce TLS certificate verification on cURL calls.
BDAPPS_VERIFY_SSL=false
